---
const navItems = [
    { linkText: 'Home', href: '/' },
    { linkText: 'Our Properties', href: '/properties' },
    { linkText: 'Contact', href: '/contact' }
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white/80 backdrop-blur-sm border-b border-primary-light/30 sticky top-0 z-50">
    <nav class="flex flex-wrap items-center justify-between gap-4 px-6 py-4 max-w-6xl mx-auto sm:px-8">
        <a href="/" class="no-underline flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-serif text-lg font-bold">D</div>
            <div>
                <span class="block text-lg font-bold text-primary-dark" style="font-family: var(--font-serif);">Domaine de la Loire</span>
                <span class="block text-xs text-text-light tracking-wider uppercase">French Countryside Rentals</span>
            </div>
        </a>
        {
            !!navItems?.length && (
                <ul class="flex flex-wrap gap-x-1 gap-y-1">
                    {navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class:list={[
                                    'inline-block px-4 py-2 rounded-md text-sm font-medium no-underline transition-colors',
                                    currentPath === item.href
                                        ? 'bg-primary/10 text-primary-dark'
                                        : 'text-text-light hover:text-primary-dark hover:bg-primary/5'
                                ]}
                            >
                                {item.linkText}
                            </a>
                        </li>
                    ))}
                </ul>
            )
        }
    </nav>
</header>
