---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
    <!-- Page Header -->
    <section class="relative overflow-hidden">
        <div class="absolute inset-0">
            <img
                src="https://images.unsplash.com/photo-1555587832-251fcdc5c4bc?w=1600&q=80"
                alt="Loire Valley château"
                class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/50"></div>
        </div>
        <div class="relative text-center py-24 sm:py-32 px-6 sm:px-8 max-w-3xl mx-auto">
            <p class="text-primary-light text-sm uppercase tracking-[0.2em] mb-4 font-semibold">Get In Touch</p>
            <h1 class="text-white text-4xl sm:text-5xl mb-6">Contact Us</h1>
            <p class="text-white/80 text-lg leading-relaxed">
                Have questions about our properties or want to book your stay?
                We'd love to hear from you.
            </p>
        </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 sm:px-8 py-20 sm:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
            <!-- Contact Form -->
            <div class="lg:col-span-3">
                <h2 class="text-2xl sm:text-3xl mb-2">Send Us a Message</h2>
                <p class="text-text-light mb-8">Fill out the form below and we'll get back to you within 24 hours.</p>

                <form name="contact" method="POST" data-netlify="true" class="space-y-6">
                    <input type="hidden" name="form-name" value="contact" />

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label for="firstName" class="block text-sm font-medium text-text mb-2">First Name</label>
                            <input
                                type="text"
                                id="firstName"
                                name="firstName"
                                required
                                class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                                placeholder="Jean"
                            />
                        </div>
                        <div>
                            <label for="lastName" class="block text-sm font-medium text-text mb-2">Last Name</label>
                            <input
                                type="text"
                                id="lastName"
                                name="lastName"
                                required
                                class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                                placeholder="Dupont"
                            />
                        </div>
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-text mb-2">Email Address</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                            placeholder="jean@example.com"
                        />
                    </div>

                    <div>
                        <label for="property" class="block text-sm font-medium text-text mb-2">Property of Interest</label>
                        <select
                            id="property"
                            name="property"
                            class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                        >
                            <option value="">Select a property (optional)</option>
                            <option value="chateau-petit">Le Château Petit - Castle Wing</option>
                            <option value="vigne-doree">La Vigne Dorée - Vineyard Cottage</option>
                            <option value="moulin-pierre">Le Moulin de Pierre - Stone Mill</option>
                            <option value="maison-tourelles">La Maison des Tourelles - Turret House</option>
                            <option value="pigeonnier">Le Pigeonnier - Dovecote</option>
                            <option value="vignes-chateau">Les Vignes du Château - Estate Farmhouse</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label for="checkin" class="block text-sm font-medium text-text mb-2">Check-in Date</label>
                            <input
                                type="date"
                                id="checkin"
                                name="checkin"
                                class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                            />
                        </div>
                        <div>
                            <label for="checkout" class="block text-sm font-medium text-text mb-2">Check-out Date</label>
                            <input
                                type="date"
                                id="checkout"
                                name="checkout"
                                class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                            />
                        </div>
                    </div>

                    <div>
                        <label for="guests" class="block text-sm font-medium text-text mb-2">Number of Guests</label>
                        <select
                            id="guests"
                            name="guests"
                            class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                        >
                            <option value="1-2">1-2 guests</option>
                            <option value="3-4">3-4 guests</option>
                            <option value="5-6">5-6 guests</option>
                            <option value="7-8">7-8 guests</option>
                            <option value="9+">9+ guests</option>
                        </select>
                    </div>

                    <div>
                        <label for="message" class="block text-sm font-medium text-text mb-2">Message</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            class="w-full px-4 py-3 rounded-lg border border-warm-dark bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-vertical"
                            placeholder="Tell us about your ideal stay..."
                        ></textarea>
                    </div>

                    <button type="submit" class="btn btn-lg w-full sm:w-auto">Send Message</button>
                </form>
            </div>

            <!-- Contact Info Sidebar -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-xl p-8 shadow-sm border border-warm-dark sticky top-24">
                    <h3 class="text-xl mb-6">Contact Information</h3>

                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <div>
                                <p class="font-semibold text-text mb-1">Address</p>
                                <p class="text-text-light text-sm leading-relaxed">Domaine de la Loire<br />Loire Valley, France</p>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            <div>
                                <p class="font-semibold text-text mb-1">Email</p>
                                <p class="text-text-light text-sm">contact@domainedelaloire.fr</p>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <div>
                                <p class="font-semibold text-text mb-1">Phone</p>
                                <p class="text-text-light text-sm">+33 2 47 00 00 00</p>
                            </div>
                        </div>
                    </div>

                    <hr class="my-8 border-warm-dark" />

                    <div>
                        <h4 class="font-semibold text-text mb-3">Response Time</h4>
                        <p class="text-text-light text-sm leading-relaxed">
                            We typically respond within 24 hours. For urgent enquiries,
                            please call us directly.
                        </p>
                    </div>

                    <hr class="my-8 border-warm-dark" />

                    <div>
                        <h4 class="font-semibold text-text mb-3">Booking Information</h4>
                        <ul class="text-text-light text-sm leading-relaxed space-y-2">
                            <li>Minimum stay: 3 nights</li>
                            <li>Check-in: 4:00 PM</li>
                            <li>Check-out: 10:00 AM</li>
                            <li>Languages: French, English</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
